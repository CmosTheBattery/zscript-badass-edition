class BadassTrilobite : cacodemon
{
	double spread;
	default
	{
		health 696;
		tag "Bad*ss Trilobite";
		obituary "%o was out-bad*ss'd by a Bad*ss Trilobite.";
	}
	states
	{
	Spawn:
		HDBD A 1 A_Look;
		Loop;
	See:
		HDBD A 1 A_FastChase;
		Loop;
	Missile:
		HDBD B 1 {
			int mul = (2*random(1,2))-3; // picks either -1 or 1
			velfromangle(40,angle+(90*mul));
			a_facetarget();
			bNOPAIN = true;
			spread = 1.5;
		}
		HDBD C 1 A_FaceTarget;
		HDBD DDDDDDDDDDDD 1 bright {
			a_spawnprojectile("trilobyteball");
			a_spawnprojectile("trilobyteball",angle:spread);
			a_spawnprojectile("trilobyteball",angle:(spread*-1.0));
			a_facetarget();
			spread += 1.5;
		}
		HDBD A 0 { a_scalevelocity(0); bNOPAIN = false; }
		Goto See;
	Pain:
		HDBD E 3 { A_Pain(); bNOPAIN = true;}
		Goto Missile;
	Death:
		HDBD G 1 A_ScreamAndUnblock;
		HDBD HIJKL 1;
		HDBD G 1 A_Scream;
		HDBD HIJKL 1;
		HDBD G 1 A_Scream;
		HDBD HIJKL 1;
		HDBD G 1 A_Scream;
		HDBD HIJKL 1;
		HDBD G 1 A_Scream;
		HDBD HIJK 1;
		HDBD L -1;
		Stop;
	}
}

class trilobyteball : cacodemonball
{
	default
	{
		speed 25;
		fastspeed 50;
		obituary "%o was out-bad*ss'd by a bad*ss trilobite";
		damagefunction (15);
	}
}

class serpentilliondollars : doomimp {
	states
	{
		spawn:
			troo ab 1 A_Look;
			loop;
		see:
			troo abcd 1 A_chase;
			loop;
		melee:
		missile:
			troo ef 2 A_FaceTarget();
			troo g 2 {
				A_FaceTarget();
				A_SpawnProjectile("miniserpent");
			}
			troo g 0 A_cposrefire;
			goto missile;
		pain:
			troo h 2;
			troo h 2 A_Pain;
			goto see;
		death:
			troo i 1 a_scream;
			troo j 1 a_noblocking;
			troo k 1;
			troo i 1 a_scream;
			troo jk 1;
			troo i 1 a_scream;
			troo jkl 1;
			troo i 1 a_scream;
			troo jklm 1;
			troo i 1 a_scream;
			troo jkl 1;
			troo m -1;			
		xdeath:
			troo n 1 a_xscream;
			troo o 1 a_noblocking;
			troo p 1;
			troo n 1 a_xscream;
			troo op 1;
			troo n 1 a_xscream;
			troo opqrst 1;
			troo p 1 a_xscream;
			troo qrst 1;
			troo p 1 a_xscream;
			troo qrst 1;
			troo u -1;
			stop;
	}
}

class miniserpent : doomimpball
{
	default {
		damage 0;
		speed 30;
		fastspeed 60;
		height 6;
		radius 6;
		seesound "imp/sight";
		+forceradiusdmg
		-zdoomtrans
		renderstyle "normal";
		deathsound "";
		obituary "%o got caught by a mob of a serpentipede's miniature clones";
		scale 0.25;
	}
	states {
		spawn:
			troo abcd 3;
			loop;
		death:
			troo n 2 a_xscream;
			troo opqrstu 2;
			stop;
		xdeath:
			troo efg 3 { a_explode(8,48,0); a_playsound("imp/melee"); }
			stop;
	}
}

//big timmy boss fight

CLASS Timmy : Revenant { 
	Default {
		Scale 2.5;
		Height 120;
		Radius 64;
		Speed 25;
		Tag "Big Timmy";	
	}
	States
	{
		Unhome:
			SKEL J 0 BRIGHT A_FaceTarget;
			SKEL K 2 A_SpawnProjectile("UnHomerTracer",50,-9,CMF_AIMOFFSET);
			SKEL K 20 A_FaceTarget;
			Goto See;
		Missile:
			SKEL J 5 BRIGHT A_FaceTarget;
			SKEL K 2 A_SpawnProjectile("UnHomerTracer",50,-9,CMF_AIMOFFSET);
			SKEL K 2 A_FaceTarget;
			Goto See;
	}
}

