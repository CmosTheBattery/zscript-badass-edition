		Mass 200;
		+AMBUSH;
		Monster;
		DropItem "ClipBox";
		DeathSound "convicts/death";
	}
	States
	{
		Spawn:
			CONV A 10 A_Look;
			Loop;
		See:
			CONV AAA 2 A_Chase();
			Loop;
		Missile:
			CONV A 4 A_FaceTarget;
			CONV F 2 A_SpawnProjectile("BulletGuru", 64, 0, 0, 0, 0);
			CONV A 2;
			CONV F 2 A_SpawnProjectile("BulletGuru", 64, 0, 0, 0, 0);
			CONV A 2;
			Goto See;
		Pain:
			CONV A 2;
			CONV A 2 A_Pain;
			Goto See;
		Death:
			CONV I 8 A_Scream;
			CONV J 8 A_NoBlocking;
			CONV K 8;
			CONV L 8;
			CONV M -1;
			Stop;
	}
}

