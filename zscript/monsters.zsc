// xdeath replacements
CLASS CorpseTosser : Cyberdemon replaces Cyberdemon { 
	Default {
		Tag "Corpse Tosser";
	}
	States
	{
		XDeath:
			CYBG A 4;
			CYBG B 4 A_XScream;
			CYBG C 4 A_NoBlocking;
			CYBG D -1;
			Stop;
	}
}

CLASS Trilobite : Cacodemon replaces Cacodemon { 
	Default {
		Tag "Trilobite";	
	}
	States
	{
		XDeath:
			HEAD M 5;
			HEAD N 5 A_XScream;
			HEAD O 5 A_NoBlocking;
			HEAD PQ 5;
			HEAD R -1;
			Stop;
	}
}

// custom monsters
CLASS FucketSpawnLocation : PainElemental { // 26016 
	Default {		
		Tag "Fucket Spawner";
	}
	States 
	{
		Missile:
			PAIN E 5 A_StartSound("IWANT3BIGMAC",CHAN_VOICE);
			PAIN A 5 A_FaceTarget;
			PAIN E 5 A_FaceTarget;
			PAIN A 5 A_FaceTarget;
			PAIN F 5 Bright A_FaceTarget;
			TNT1 A 0 A_StartSound("Sraka",CHAN_AUTO);
			PAIN F 0 Bright A_SpawnProjectile("FucketGrenadeGravity", 32, 0, -10);
			PAIN F 0 Bright A_SpawnProjectile("FucketGrenadeGravity", 32, 0, 0);
			PAIN F 0 Bright A_SpawnProjectile("FucketGrenadeGravity", 32, 0, 10);
			PAIN A 15 A_FaceTarget;
			PAIN E 5 A_FaceTarget;
			PAIN A 5 A_FaceTarget;
			PAIN E 5 A_FaceTarget;
			PAIN A 5 A_FaceTarget;
			Goto See;
		Death:
			PAIN H 8 Bright;
			PAIN I 8 Bright A_Scream;
			PAIN J 8 Bright;
			PAIN K 8 Bright {
				for (int i; i < 4; i++) {
					A_SpawnProjectile("FucketGrenadeGravity", 32, 0, 0, 90*i, CMF_AIMDIRECTION);
				}
			}
			PAIN LM 8 Bright;
			Stop;
	}
}

CLASS TheNuker : Cyberdemon  { //26017
	Default {
		
		Obituary "$OB_NUKE_TRIPOD";
		Tag "The Nuker";
	}
	States
	{
		Missile:
			CYBR EEEF 8 A_FaceTarget;
			CYBR F 4 A_SpawnProjectile("PlasmaTesticle");
			CYBR A 8 A_FaceTarget;
			CYBR FFF 2 A_SpawnProjectile("PlasmaTesticle");
			Goto See;
		Death:
			PLAY O 3 {
				a_settranslation("nukergib");
				a_xscream();
				a_noblocking();
				a_setscale(2.5,2.5);
			}
			PLAY PQRSTUV 3;
			PLAY W 35;
			PLAY WWWWWWWW 1 A_SetScale(scale.x,scale.y-0.3);
			PLAY W -1;
			Stop;
	}
}

CLASS NuclearFucket : CustomInventory  {//26018
	Default {
		Tag "Nuclear Fucket";
		Inventory.PickupMessage "$STEPPEDNUCLEARFUCKET";
	}
	States {
		Spawn:
			PLAY ABCD 6 Bright A_SetScale(1,0.40);
			Loop;
		Pickup:
			TNT1 A 0
			{
			    A_StartSound("Sraka");
			    A_SpawnItemEx("PlasmaNuke");
			}
	}
}

CLASS TechnoSpiderDriver : SpiderMastermind { // 26019
	Default {
		
		Tag "Technospider w/ Tough Sailor";
	}
	States
	{
		Death:
			SPID J 20 A_Scream;
			SPID K 5
			{
			    A_NoBlocking();
			    A_SpawnItemEx("DriverSailor");
			}
			SPID LMNOPQR 10;
			SPID S -1;
			Stop;
	}
}

CLASS DriverSailor : WolfensteinSS  { //26020
	Default {
		
		Health 100;
		Speed 12;
		PainChance 200;
		ReactionTime 2;
		Dropitem "ClipBox";
		Tag "Tough Sailor";
	}
	States
	{
		Missile:
			SSWV E 3 A_FaceTarget;
			SSWV F 3 A_FaceTarget;
			SSWV G 1 Bright A_CPosAttack;
			SSWV G 1 Bright A_CPosAttack;
			SSWV F 3 A_FaceTarget;
			SSWV G 1 Bright A_CPosAttack;
			SSWV G 1 Bright A_CPosAttack;
			SSWV F 1 A_CPosRefire;
			Goto Missile+1;
		Pain:
			SSWV H 1;
			SSWV H 2 A_Pain;
			Goto See;
		Death:
			SSWV N 0;
			Goto XDeath;
		XDeath:
			SSWV N 5;
			SSWV O 2 A_StartSound("wolfss/death");
			SSWV O 3 A_XScream;
			SSWV P 5 A_NoBlocking;
			SSWV QRSTU 5;
			SSWV V -1;
			Stop;
		Raise:
			SSWV V 2 A_StartSound("sailor/raise");
			SSWV UTSRQPON 2;
			Goto See;
	}
}

