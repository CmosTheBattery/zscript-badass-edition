			Stop;
		XDeath:
			SSWV N 5;
			SSWV O 5 A_XScream;
			SSWV P 0 A_SpawnItemEx("Clip");
			SSWV P 5 A_NoBlocking;
			SSWV QRSTU 5;
			SSWV V -1;
			Stop;
	}
}

CLASS WorkerZombie : ZombieMan { //26022 
	Default {
		
		Health 10;
		Speed 10;
		PainChance 200;
		DropItem "SingularBulletAmmo";
		Tag "Worker Zombie";
	}
	States
	{
		Spawn:
			POSS ABCDBADADBDCACABDACABCD 15 A_Look;
			Loop;
		See:
			POSS AABBCCDD 3 A_Chase("Melee");
			Loop;
		Melee:
